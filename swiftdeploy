def mode_name(value):
    return "canary" if int(value) == 1 else "stable"


def chaos_name(value):
    value = int(value)
    if value == 1:
        return "slow"
    if value == 2:
        return "error"
    return "none"


def command_init(args=None):
    manifest = load_manifest()
    mapping = replacement_map(manifest)

    GENERATED.mkdir(exist_ok=True)

    if not POLICIES.exists():
        raise RuntimeError("policies/ directory is missing. OPA requires Rego files.")

    rego_files = list(POLICIES.glob("*.rego"))

    if not rego_files:
        raise RuntimeError("No .rego files found in policies/. OPA has no policy to load.")

    render_template(
        TEMPLATES / "docker-compose.yml.tpl",
        COMPOSE_FILE,
        mapping,
    )

    render_template(
        TEMPLATES / "nginx.conf.tpl",
        NGINX_FILE,
        mapping,
    )

    print("[OK] Generated deployment files:")
    print(f" - {COMPOSE_FILE}")
    print(f" - {NGINX_FILE}")
    print(f"[INFO] Mode: {required(manifest, 'services.mode')}")
    print(f"[INFO] Nginx public port: {required(manifest, 'nginx.port')}")
    print(f"[INFO] OPA policies loaded from: {POLICIES}")
    print(f"[INFO] Rego policy files detected: {len(rego_files)}")


def check_port_available(port):
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)

    try:
        sock.bind(("127.0.0.1", int(port)))
        sock.close()
        return True
    except OSError:
        sock.close()
        return False


def docker_container_exists(name):
    result = run(
        ["docker", "ps", "-a", "--filter", f"name={name}", "--format", "{{.Names}}"],
        capture=True,
        check=False,
    )

    return name in result.stdout.splitlines()


def pass_check(message):
    print(f"[PASS] {message}")


def fail_check(message):
    print(f"[FAIL] {message}")
    raise RuntimeError(message)


def command_validate(args=None):
    manifest = load_manifest()

    required_keys = [
        "project.name",
        "project.version",
        "project.contact",
        "services.name",
        "services.image",
        "services.port",
        "services.mode",
        "services.app_version",
        "services.restart_policy",
        "nginx.image",
        "nginx.port",
        "nginx.proxy_timeout",
        "network.name",
        "network.driver_type",
        "logs.volume_name",
        "policy.opa_url",
        "policy.infrastructure.min_disk_free_gb",
        "policy.infrastructure.max_cpu_load",
        "policy.canary.max_error_rate",
        "policy.canary.max_p99_latency_seconds",
        "policy.canary.window_seconds",
    ]

    for key in required_keys:
        required(manifest, key)

    pass_check("manifest.yaml exists and required keys are present")

    if not (TEMPLATES / "docker-compose.yml.tpl").exists():
        fail_check("Docker Compose template is missing")

    if not (TEMPLATES / "nginx.conf.tpl").exists():
        fail_check("Nginx template is missing")

    pass_check("required templates exist")

    if not POLICIES.exists() or not list(POLICIES.glob("*.rego")):
        fail_check("policies/ must contain at least one .rego file")

    pass_check("OPA Rego policy files exist")

    if not COMPOSE_FILE.exists() or not NGINX_FILE.exists():
        fail_check("generated files are missing; run './swiftdeploy init' first")

    pass_check("generated Docker Compose and Nginx files exist")

    run(["docker", "version"], capture=True)
    pass_check("Docker Engine is reachable")

    run(["docker", "compose", "version"], capture=True)
    pass_check("Docker Compose is available")

    image_name = str(required(manifest, "services.image"))
    run(["docker", "image", "inspect", image_name], capture=True)
    pass_check(f"Docker image exists locally: {image_name}")

    config_result = run(compose_command() + ["config"], capture=True)
    pass_check("generated docker-compose.yml is valid")

    compose_text = COMPOSE_FILE.read_text(encoding="utf-8")
    nginx_conf = NGINX_FILE.read_text(encoding="utf-8")

    if 'X-Deployed-By "swiftdeploy"' not in nginx_conf:
        fail_check("Nginx config does not add X-Deployed-By header")

    pass_check("Nginx adds X-Deployed-By header")

    app_block = compose_text.split("  nginx:")[0]

    if "\n    ports:" in app_block:
        fail_check("app service must not publish a host port")

    pass_check("app service is internal-only; no host port is published")

    if "opa:" not in compose_text:
        fail_check("OPA service is missing from generated docker-compose.yml")

    pass_check("OPA sidecar service exists in generated docker-compose.yml")

    if "127.0.0.1:8181:8181" not in compose_text:
        fail_check("OPA must bind only to localhost, not public interfaces")

    pass_check("OPA is bound to localhost only")

    if "cap_drop:" not in compose_text or "no-new-privileges:true" not in compose_text:
        fail_check("container security hardening is missing")

    pass_check("containers drop Linux capabilities and use no-new-privileges")

    nginx_port = int(required(manifest, "nginx.port"))

    if check_port_available(nginx_port) or docker_container_exists("swiftdeploy-nginx"):
        pass_check(f"Nginx port {nginx_port} is available or already used by this stack")
    else:
        fail_check(f"Nginx port {nginx_port} is already in use by another process")

    print("[OK] Validation completed successfully")


def wait_for_health(port, expected_mode=None):
    url = f"http://localhost:{port}/healthz"

    print(f"[INFO] Waiting for health check: {url}")

    for _ in range(30):
        response = http_get(url)

        if response["ok"] and response["status"] == 200:
            print("[OK] Service is healthy")
            print(response["body"])

            if expected_mode == "canary":
                root_response = http_get(f"http://localhost:{port}/")
                if root_response["headers"].get("X-Mode") == "canary":
                    print("[OK] Canary response header detected: X-Mode=canary")
                else:
                    print("[WARN] Canary mode is running, but X-Mode header was not detected")

            return True

        time.sleep(2)

    raise RuntimeError("Service did not become healthy in time")


def command_deploy(args=None):
    manifest = load_manifest()

    print("[INFO] Initialising generated files")
    command_init()

    ensure_opa_running(manifest)

    print("[INFO] Running pre-deploy infrastructure policy check")
    infrastructure_decision = check_infrastructure_policy(manifest, "pre-deploy")
    enforce_policy(infrastructure_decision, "deploy")

    print("[INFO] Running pre-flight validation")
    command_validate()

    nginx_port = int(required(manifest, "nginx.port"))

    print("[INFO] Starting full stack with Docker Compose")
    run(compose_command() + ["up", "-d"])

    wait_for_health(nginx_port, required(manifest, "services.mode"))

    print(f"[OK] Deployment complete: http://localhost:{nginx_port}")


def update_manifest_mode(new_mode):
    text = MANIFEST.read_text(encoding="utf-8").splitlines()
    output = []
    in_services = False
    replaced = False

    for line in text:
        stripped = line.strip()

        if line and not line.startswith(" "):
            in_services = stripped == "services:"

        if in_services and stripped.startswith("mode:"):
            indent = line[: len(line) - len(line.lstrip(" "))]
            output.append(f"{indent}mode: {new_mode}")
            replaced = True
        else:
            output.append(line)

    if not replaced:
        raise RuntimeError("Could not find services.mode in manifest.yaml")

    MANIFEST.write_text("\n".join(output) + "\n", encoding="utf-8")


def command_promote(args):
    manifest = load_manifest()

    ensure_opa_running(manifest)

    print("[INFO] Running pre-promote canary safety policy check")
    canary_metrics = collect_canary_metrics(manifest)
    print(f"[INFO] Canary metrics: {json.dumps(canary_metrics)}")

    canary_decision = check_canary_policy(manifest, "pre-promote", canary_metrics)
    enforce_policy(canary_decision, f"promote {args.mode}")

    print(f"[INFO] Updating manifest mode to: {args.mode}")
    update_manifest_mode(args.mode)

    print("[INFO] Regenerating files from manifest")
    command_init()

    updated_manifest = load_manifest()
    nginx_port = int(required(updated_manifest, "nginx.port"))

    print("[INFO] Recreating app service only")
    run(compose_command() + ["up", "-d", "--no-deps", "--force-recreate", "app"])

    wait_for_health(nginx_port, args.mode)

    print(f"[OK] Promotion complete. Current mode: {args.mode}")


def append_history(record):
    with HISTORY_FILE.open("a", encoding="utf-8") as file:
        file.write(json.dumps(record) + "\n")


def command_status(args):
    manifest = load_manifest()

    ensure_opa_running(manifest)

    interval = args.interval

    print("[INFO] Starting live status dashboard. Press Ctrl+C to stop.")

    previous_metrics = None
    previous_time = None

    try:
        while True:
            now = time.time()
            current_metrics = scrape_metrics(manifest)

            if previous_metrics is None:
                window_metrics = {
                    "requests_total": 0,
                    "errors_total": 0,
                    "error_rate": 0.0,
                    "req_per_second": 0.0,
                    "p99_latency_seconds": 0.0,
                    "app_mode": int(current_metrics["gauges"].get("app_mode", 0)),
                    "chaos_active": int(current_metrics["gauges"].get("chaos_active", 0)),
                    "window_seconds": 0,
                }
            else:
                elapsed = now - previous_time
                window_metrics = calculate_window_metrics(previous_metrics, current_metrics, elapsed)

            infra_decision = check_infrastructure_policy(manifest, "status")
            canary_decision = check_canary_policy(manifest, "status", window_metrics)

            os.system("cls" if os.name == "nt" else "clear")

            print("SwiftDeploy Live Status")
            print("======================")
            print(f"Time: {utc_now()}")
            print(f"App URL: {app_url(manifest)}")
            print(f"Mode: {mode_name(window_metrics['app_mode'])}")
            print(f"Chaos: {chaos_name(window_metrics['chaos_active'])}")
            print("")
            print("Metrics")
            print("-------")
            print(f"Requests/sec: {window_metrics['req_per_second']}")
            print(f"Window requests: {window_metrics['requests_total']}")
            print(f"Window errors: {window_metrics['errors_total']}")
            print(f"Error rate: {window_metrics['error_rate']}")
            print(f"P99 latency seconds: {window_metrics['p99_latency_seconds']}")
            print("")
            print("Policy Compliance")
            print("-----------------")
            print(f"Infrastructure: {'PASS' if infra_decision['allow'] else 'FAIL'} - {infra_decision['reason']}")
            for violation in infra_decision.get("violations", []):
                print(f"  - {violation}")

            print(f"Canary: {'PASS' if canary_decision['allow'] else 'FAIL'} - {canary_decision['reason']}")
            for violation in canary_decision.get("violations", []):
                print(f"  - {violation}")

            append_history({
                "timestamp": utc_now(),
                "metrics": window_metrics,
                "policies": {
                    "infrastructure": infra_decision,
                    "canary": canary_decision,
                },
            })

            previous_metrics = current_metrics
            previous_time = now

            if args.once:
                break

            time.sleep(interval)

    except KeyboardInterrupt:
        print("\n[OK] Status dashboard stopped")


def command_audit(args=None):
    if not HISTORY_FILE.exists():
        raise RuntimeError("history.jsonl was not found. Run './swiftdeploy status' first.")

    records = []

    with HISTORY_FILE.open("r", encoding="utf-8") as file:
        for line in file:
            if line.strip():
                try:
                    records.append(json.loads(line))
                except json.JSONDecodeError:
                    pass

    if not records:
        raise RuntimeError("history.jsonl is empty. No audit data available.")

    timeline_rows = []
    violation_rows = []

    previous_mode = None
    previous_chaos = None

    for record in records:
        timestamp = record.get("timestamp", "")
        metrics = record.get("metrics", {})
        policies = record.get("policies", {})

        current_mode = mode_name(metrics.get("app_mode", 0))
        current_chaos = chaos_name(metrics.get("chaos_active", 0))

        if previous_mode is None or current_mode != previous_mode:
            timeline_rows.append([
                timestamp,
                "mode_change",
                f"Mode observed as {current_mode}",
            ])

        if previous_chaos is None or current_chaos != previous_chaos:
            timeline_rows.append([
                timestamp,
                "chaos_state",
                f"Chaos state observed as {current_chaos}",
            ])

        for domain, decision in policies.items():
            if not decision.get("allow", False):
                violation_rows.append([
                    timestamp,
                    domain,
                    decision.get("reason", "No reason"),
                    "; ".join(decision.get("violations", [])),
                ])

        previous_mode = current_mode
        previous_chaos = current_chaos

    lines = []
    lines.append("# SwiftDeploy Audit Report")
    lines.append("")
    lines.append(f"Generated at: `{utc_now()}`")
    lines.append("")
    lines.append("## Summary")
    lines.append("")
    lines.append(f"- Total status samples analysed: `{len(records)}`")
    lines.append(f"- Timeline events detected: `{len(timeline_rows)}`")
    lines.append(f"- Policy violations detected: `{len(violation_rows)}`")
    lines.append("")
    lines.append("## Timeline")
    lines.append("")
    lines.append("| Time | Event | Details |")
    lines.append("|---|---|---|")

    for row in timeline_rows:
        lines.append(f"| {row[0]} | {row[1]} | {row[2]} |")

    lines.append("")
    lines.append("## Policy Violations")
    lines.append("")

    if violation_rows:
        lines.append("| Time | Domain | Reason | Violations |")
        lines.append("|---|---|---|---|")

        for row in violation_rows:
            lines.append(f"| {row[0]} | {row[1]} | {row[2]} | {row[3]} |")
    else:
        lines.append("No policy violations were recorded in the audit history.")

    lines.append("")
    lines.append("## Notes")
    lines.append("")
    lines.append("This report was generated from `history.jsonl`, which is written by the `swiftdeploy status` command.")
    lines.append("Each status sample includes metrics and policy decisions returned by OPA.")

    AUDIT_REPORT.write_text("\n".join(lines) + "\n", encoding="utf-8")

    print(f"[OK] Audit report generated: {AUDIT_REPORT}")


def command_teardown(args=None):
    if not COMPOSE_FILE.exists():
        print("[INFO] Generated compose file missing; regenerating first")
        command_init()

    print("[INFO] Tearing down stack and removing volumes")
    run(compose_command() + ["down", "-v", "--remove-orphans"])

    print("[OK] Containers, network, and named volumes removed")


def main():
    parser = argparse.ArgumentParser(
        prog="swiftdeploy",
        description="Manifest-driven Docker Compose, Nginx, OPA, observability, and audit automation tool",
    )

    subcommands = parser.add_subparsers(dest="command")

    subcommands.add_parser("init", help="Generate Docker Compose and Nginx files")
    subcommands.add_parser("validate", help="Run deployment pre-flight checks")
    subcommands.add_parser("deploy", help="Deploy the stack with OPA policy gate")
    subcommands.add_parser("teardown", help="Remove containers, network, and volumes")
    subcommands.add_parser("audit", help="Generate audit_report.md from history.jsonl")

    promote = subcommands.add_parser("promote", help="Promote deployment mode with OPA policy gate")
    promote.add_argument("mode", choices=["stable", "canary"])

    status = subcommands.add_parser("status", help="Show live observability and policy dashboard")
    status.add_argument("--interval", type=int, default=5)
    status.add_argument("--once", action="store_true")

    args = parser.parse_args()

    try:
        if args.command == "init":
            command_init(args)
        elif args.command == "validate":
            command_validate(args)
        elif args.command == "deploy":
            command_deploy(args)
        elif args.command == "promote":
            command_promote(args)
        elif args.command == "status":
            command_status(args)
        elif args.command == "audit":
            command_audit(args)
        elif args.command == "teardown":
            command_teardown(args)
        else:
            parser.print_help()
            sys.exit(1)
    except Exception as error:
        print(f"[ERROR] {error}")
        sys.exit(1)


if __name__ == "__main__":
    main()
