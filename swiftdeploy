    }


def render_template(template_path, output_path, mapping):
    content = template_path.read_text(encoding="utf-8")

    for key, value in mapping.items():
        content = content.replace(key, value)

    output_path.write_text(content, encoding="utf-8")


def run(command, capture=False, check=True):
    result = subprocess.run(
        command,
        cwd=ROOT,
        text=True,
        stdout=subprocess.PIPE if capture else None,
        stderr=subprocess.PIPE if capture else None,
    )

    if check and result.returncode != 0:
        if capture:
            if result.stdout:
                print(result.stdout)
            if result.stderr:
                print(result.stderr)
        raise RuntimeError(f"Command failed: {' '.join(command)}")

    return result


def compose_command():
    return ["docker", "compose", "-f", str(COMPOSE_FILE)]


def http_get(url, timeout=5):
    try:
        request = urllib.request.Request(url, method="GET")
        with urllib.request.urlopen(request, timeout=timeout) as response:
            body = response.read().decode("utf-8", errors="replace")
            return {
                "ok": True,
                "status": response.status,
                "body": body,
                "headers": dict(response.headers),
                "error_type": None,
                "error": None,
            }
    except urllib.error.HTTPError as error:
        return {
            "ok": False,
            "status": error.code,
            "body": error.read().decode("utf-8", errors="replace"),
            "headers": {},
            "error_type": "http_error",
            "error": f"HTTP {error.code}",
        }
    except urllib.error.URLError as error:
        reason = str(error.reason)
        if "timed out" in reason.lower():
            error_type = "timeout"
        elif "connection refused" in reason.lower():
            error_type = "connection_refused"
        else:
            error_type = "connection_error"

        return {
            "ok": False,
            "status": None,
            "body": "",
            "headers": {},
            "error_type": error_type,
            "error": reason,
        }
    except Exception as error:
        return {
            "ok": False,
            "status": None,
            "body": "",
            "headers": {},
            "error_type": "unexpected_error",
            "error": str(error),
        }


def http_post_json(url, payload, timeout=8):
    try:
        data = json.dumps(payload).encode("utf-8")
        request = urllib.request.Request(
            url,
            data=data,
            method="POST",
            headers={"Content-Type": "application/json"},
        )

        with urllib.request.urlopen(request, timeout=timeout) as response:
            body = response.read().decode("utf-8", errors="replace")
            return {
                "ok": True,
                "status": response.status,
                "json": json.loads(body),
                "body": body,
                "error_type": None,
                "error": None,
            }
    except urllib.error.HTTPError as error:
        body = error.read().decode("utf-8", errors="replace")
        return {
            "ok": False,
            "status": error.code,
            "json": None,
            "body": body,
            "error_type": "opa_http_error",
            "error": f"OPA returned HTTP {error.code}",
        }
    except urllib.error.URLError as error:
        reason = str(error.reason)
        if "timed out" in reason.lower():
            error_type = "opa_timeout"
        elif "connection refused" in reason.lower():
            error_type = "opa_connection_refused"
        else:
            error_type = "opa_connection_error"

        return {
            "ok": False,
            "status": None,
            "json": None,
            "body": "",
            "error_type": error_type,
            "error": reason,
        }
    except json.JSONDecodeError as error:
        return {
            "ok": False,
            "status": None,
            "json": None,
            "body": "",
            "error_type": "opa_invalid_json",
            "error": str(error),
        }
    except Exception as error:
        return {
            "ok": False,
            "status": None,
            "json": None,
            "body": "",
            "error_type": "opa_unexpected_error",
            "error": str(error),
        }


def opa_url(manifest):
    return str(optional(manifest, "policy.opa_url", "http://localhost:8181")).rstrip("/")


def metrics_url(manifest):
    port = int(required(manifest, "nginx.port"))
    return f"http://localhost:{port}/metrics"


def app_url(manifest):
    port = int(required(manifest, "nginx.port"))
    return f"http://localhost:{port}"


def wait_for_opa(manifest, seconds=20):
    url = f"{opa_url(manifest)}/health"

    for _ in range(seconds):
        response = http_get(url, timeout=2)
        if response["ok"]:
            return True
        time.sleep(1)

    return False


def ensure_opa_running(manifest):
    print("[INFO] Starting OPA policy sidecar")
    run(compose_command() + ["up", "-d", "opa"])

    if not wait_for_opa(manifest):
        raise RuntimeError(
            "OPA is unavailable. Deployment is blocked because policy decisions cannot be evaluated."
        )

    print("[OK] OPA policy sidecar is reachable")


def get_memory_stats():
    if os.name == "nt":
        try:
            import ctypes

            class MEMORYSTATUSEX(ctypes.Structure):
                _fields_ = [
                    ("dwLength", ctypes.c_ulong),
                    ("dwMemoryLoad", ctypes.c_ulong),
                    ("ullTotalPhys", ctypes.c_ulonglong),
                    ("ullAvailPhys", ctypes.c_ulonglong),
                    ("ullTotalPageFile", ctypes.c_ulonglong),
                    ("ullAvailPageFile", ctypes.c_ulonglong),
                    ("ullTotalVirtual", ctypes.c_ulonglong),
                    ("ullAvailVirtual", ctypes.c_ulonglong),
                    ("ullAvailExtendedVirtual", ctypes.c_ulonglong),
                ]

            memory = MEMORYSTATUSEX()
            memory.dwLength = ctypes.sizeof(MEMORYSTATUSEX)
            ctypes.windll.kernel32.GlobalMemoryStatusEx(ctypes.byref(memory))

            return {
                "total_gb": round(memory.ullTotalPhys / (1024 ** 3), 2),
                "available_gb": round(memory.ullAvailPhys / (1024 ** 3), 2),
            }
        except Exception:
            return {"total_gb": None, "available_gb": None}

    try:
        values = {}
        with open("/proc/meminfo", "r", encoding="utf-8") as file:
            for line in file:
                key, value = line.split(":", 1)
                values[key] = int(value.strip().split()[0])

        return {
            "total_gb": round(values.get("MemTotal", 0) / 1024 / 1024, 2),
            "available_gb": round(values.get("MemAvailable", 0) / 1024 / 1024, 2),
        }
    except Exception:
        return {"total_gb": None, "available_gb": None}


def get_host_stats():
    disk = shutil.disk_usage(ROOT)

    try:
        cpu_load = os.getloadavg()[0]
    except Exception:
        cpu_load = 0.0

    return {
        "disk_free_gb": round(disk.free / (1024 ** 3), 2),
        "disk_total_gb": round(disk.total / (1024 ** 3), 2),
        "cpu_load": round(cpu_load, 2),
        "memory": get_memory_stats(),
    }


def opa_decision(manifest, domain, package_path, input_data):
    url = f"{opa_url(manifest)}/v1/data/{package_path}/decision"
    response = http_post_json(url, {"input": input_data})

    if not response["ok"]:
        return {
            "allow": False,
            "domain": domain,
            "reason": f"OPA decision failed: {response['error_type']}",
            "violations": [response["error"] or "OPA was unavailable"],
            "opa_available": False,
        }

    payload = response["json"]

    if not isinstance(payload, dict) or "result" not in payload:
        return {
            "allow": False,
            "domain": domain,
            "reason": "OPA returned an invalid decision shape.",
            "violations": ["missing result object"],
            "opa_available": True,
        }

    decision = payload["result"]

    if not isinstance(decision, dict):
        return {
            "allow": False,
            "domain": domain,
            "reason": "OPA returned an invalid decision type.",
            "violations": ["decision is not an object"],
            "opa_available": True,
        }

    return {
        "allow": bool(decision.get("allow", False)),
        "domain": decision.get("domain", domain),
        "reason": decision.get("reason", "No reason returned by OPA."),
        "violations": decision.get("violations", []),
        "opa_available": True,
    }


