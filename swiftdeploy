    )

    print_policy_decision(decision)

    return decision


def enforce_policy(decision, action_name):
    if decision["allow"]:
        print(f"[OK] Policy allowed {action_name}")
        return

    print(f"[POLICY BLOCK] {action_name} was blocked by {decision['domain']} policy")
    print(f"[REASON] {decision['reason']}")

    for violation in decision.get("violations", []):
        print(f" - {violation}")

    raise RuntimeError(f"{action_name} blocked by OPA policy")


def print_policy_decision(decision):
    status = "PASS" if decision["allow"] else "FAIL"
    print(f"[{status}] {decision['domain']} policy: {decision['reason']}")

    for violation in decision.get("violations", []):
        print(f" - {violation}")


def parse_labels(label_text):
    labels = {}
    parts = re.findall(r'(\w+)="([^"]*)"', label_text)

    for key, value in parts:
        labels[key] = value

    return labels


def parse_metrics(text):
    parsed = {
        "requests": {},
        "duration_buckets": {},
        "duration_counts": {},
        "gauges": {},
    }

    for raw_line in text.splitlines():
        line = raw_line.strip()

        if not line or line.startswith("#"):
            continue

        metric_with_labels = re.match(r"^([a-zA-Z_:][a-zA-Z0-9_:]*)\{([^}]*)\}\s+([0-9.eE+-]+)$", line)
        metric_without_labels = re.match(r"^([a-zA-Z_:][a-zA-Z0-9_:]*)\s+([0-9.eE+-]+)$", line)

        if metric_with_labels:
            name = metric_with_labels.group(1)
            labels = parse_labels(metric_with_labels.group(2))
            value = float(metric_with_labels.group(3))

            if name == "http_requests_total":
                key = (
                    labels.get("method", ""),
                    labels.get("path", ""),
                    labels.get("status_code", ""),
                )
                parsed["requests"][key] = value

            elif name == "http_request_duration_seconds_bucket":
                le = labels.get("le", "")
                key = (
                    labels.get("method", ""),
                    labels.get("path", ""),
                    le,
                )
                parsed["duration_buckets"][key] = value

            elif name == "http_request_duration_seconds_count":
                key = (
                    labels.get("method", ""),
                    labels.get("path", ""),
                )
                parsed["duration_counts"][key] = value

        elif metric_without_labels:
            name = metric_without_labels.group(1)
            value = float(metric_without_labels.group(2))
            parsed["gauges"][name] = value

    return parsed


def scrape_metrics(manifest):
    response = http_get(metrics_url(manifest), timeout=5)

    if not response["ok"]:
        raise RuntimeError(
            f"Could not scrape /metrics: {response['error_type']} - {response['error']}"
        )

    return parse_metrics(response["body"])


def calculate_window_metrics(before, after, elapsed_seconds):
    total_requests = 0
    error_requests = 0

    all_request_keys = set(before["requests"].keys()) | set(after["requests"].keys())

    for key in all_request_keys:
        before_value = before["requests"].get(key, 0)
        after_value = after["requests"].get(key, 0)
        delta = max(0, after_value - before_value)

        total_requests += delta

        status_code = key[2]
        if status_code.startswith("5"):
            error_requests += delta

    error_rate = 0.0
    if total_requests > 0:
        error_rate = error_requests / total_requests

    req_per_second = 0.0
    if elapsed_seconds > 0:
        req_per_second = total_requests / elapsed_seconds

    bucket_totals = {}
    all_bucket_keys = set(before["duration_buckets"].keys()) | set(after["duration_buckets"].keys())

    for key in all_bucket_keys:
        le = key[2]
        if le == "+Inf":
            continue

        before_value = before["duration_buckets"].get(key, 0)
        after_value = after["duration_buckets"].get(key, 0)
        delta = max(0, after_value - before_value)

        try:
            le_value = float(le)
        except ValueError:
            continue

        bucket_totals[le_value] = bucket_totals.get(le_value, 0) + delta

    p99_latency = 0.0

    if total_requests > 0 and bucket_totals:
        target = total_requests * 0.99

        for bucket in sorted(bucket_totals.keys()):
            if bucket_totals[bucket] >= target:
                p99_latency = bucket
                break

        if p99_latency == 0.0:
            p99_latency = max(bucket_totals.keys())

    return {
        "requests_total": int(total_requests),
        "errors_total": int(error_requests),
        "error_rate": round(error_rate, 5),
        "req_per_second": round(req_per_second, 3),
        "p99_latency_seconds": round(p99_latency, 3),
        "app_mode": int(after["gauges"].get("app_mode", 0)),
        "chaos_active": int(after["gauges"].get("chaos_active", 0)),
        "window_seconds": round(elapsed_seconds, 2),
    }


def collect_canary_metrics(manifest, wait_seconds=None):
    if wait_seconds is None:
        wait_seconds = int(required(manifest, "policy.canary.window_seconds"))

    print(f"[INFO] Scraping /metrics for {wait_seconds} seconds to evaluate canary safety")
    before = scrape_metrics(manifest)
    start = time.time()

    time.sleep(wait_seconds)

    after = scrape_metrics(manifest)
    elapsed = time.time() - start

    metrics = calculate_window_metrics(before, after, elapsed)

    return metrics


